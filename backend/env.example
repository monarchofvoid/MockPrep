# ════════════════════════════════════════════════════════════════════════════
# VYAS v2.0 — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked  ← REQUIRED
#   3. Never commit .env to version control  (.gitignore already excludes it)
#   4. Rotate all secrets before deploying to production
#
# Generate a secure random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=VYAS
APP_VERSION=2.0.0
ENVIRONMENT=development        # "development" or "production"
DEBUG=false

# ── Auth — Access Tokens ─────────────────────────────────────────────────────
# SECURITY: In production this MUST be ≤ 30 minutes (enforced by validator).
# 7-day values completely negate the refresh-token security architecture.
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_HEX_STRING    # ← REQUIRED
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── Auth — Refresh Tokens ────────────────────────────────────────────────────
# Must be different from SECRET_KEY
REFRESH_SECRET_KEY=REPLACE_WITH_DIFFERENT_LONG_RANDOM_HEX    # ← REQUIRED
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_SECURE=false        # Set to true in production (HTTPS only)
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# ── Auth — Brute Force Protection ────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite is for local dev only. Use PostgreSQL in production.
# Render: fromDatabase property populates this automatically in render.yaml
DATABASE_URL=postgresql://user:password@localhost:5432/vyas_dev    # ← REQUIRED

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for: Celery broker, Celery result backend, rate limiting, job status
# Local dev: redis://localhost:6379/0  (Docker Compose provides this)
# Production: use Upstash Redis (free tier available)
#   Get URL from: https://console.upstash.com  →  Create database → REST URL
REDIS_URL=redis://localhost:6379/0

# Celery uses the same Redis — keep in sync with REDIS_URL
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Question Bank ────────────────────────────────────────────────────────────
# Path to the question_bank directory (relative to backend/ or absolute)
QB_ROOT=../question_bank

# ── Groq / AI ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_API_KEY    # ← REQUIRED (get from console.groq.com)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TPM_LIMIT=8000           # Free tier limit. Raise if you upgrade to paid Groq plan.

# AI generation tuning (safe defaults — only change after measuring actual token usage)
AI_TIMEOUT=60.0
AI_MAX_RETRIES=3
AI_TEMPERATURE_MOCK=0.5
AI_TEMPERATURE_TUTOR=0.3
AI_MAX_TOKENS_MOCK=7500
AI_MAX_TOKENS_TUTOR=2048
AI_MOCK_BATCH_SIZE=4
AI_BATCH_DELAY=42.0
AI_RATE_LIMIT_BACKOFF=30.0
AI_TOKEN_SAFETY_MARGIN=0.80
AI_TOKENS_PER_QUESTION=1400
AI_OUTPUT_TOKEN_OVERHEAD=1.20
AI_PROMPT_TOKEN_ESTIMATE=262

# ── Gemini (legacy — used by tutor.py) ───────────────────────────────────────
GEMINI_API_KEY_TUTOR=YOUR_GEMINI_API_KEY_HERE
GEMINI_API_KEY_MOCK=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_TUTOR=gemini-2.0-flash
GEMINI_MODEL_MOCK=gemini-2.0-flash

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_*) for development
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID        # ← REQUIRED for payments
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_RAZORPAY_KEY_SECRET # ← REQUIRED for payments
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET  # ← REQUIRED for webhooks
RAZORPAY_CURRENCY=INR

# ── Wallet / Credit System ────────────────────────────────────────────────────
SIGNUP_BONUS_MICROCREDITS=500     # 5 credits free on signup (100 microcredits = 1 credit)
MICROCREDITS_PER_CREDIT=100
COST_PER_QUESTION_MICROCREDITS=15 # 15 microcredits per AI-generated question
LOW_CREDIT_WARN_MICROCREDITS=150  # Warn user when balance < 1.5 credits

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=REPLACE_WITH_YOUR_BREVO_API_KEY    # ← REQUIRED for emails
FROM_EMAIL=noreply@yourdomain.com
OWNER_EMAIL=you@yourdomain.com
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_AI_REQUESTS=5
RATE_LIMIT_AI_WINDOW=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_PAYMENT_REQUESTS=20
RATE_LIMIT_PAYMENT_WINDOW=60

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text    # "text" for dev (colored), "json" for production (structured)

# ── Sentry (optional but recommended for production) ──────────────────────────
# Get DSN from: https://sentry.io → Project → Settings → SDK Setup
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
