# ── Backend .env ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Database connection string
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./mockprep.db

# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/mockprep

# Path to question_bank folder (relative to backend/ or absolute)
QB_ROOT=../question_bank

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Secret
SECRET_KEY = "your-secret-key-change-in-production"   # move to .env
# ── Password Reset (Resend) ────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Base URL of your frontend (used to build the reset link in emails)
FRONTEND_URL=http://localhost:5173

# Email address where contact form submissions are sent
OWNER_EMAIL=your@email.com